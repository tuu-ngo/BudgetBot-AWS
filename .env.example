# =============================================================================
# BudgetBot — environment configuration
# Copy to .env and fill in values.
# =============================================================================

# ── AI backend ───────────────────────────────────────────────────────────────
# Options: bedrock | local
# local  = rule-based keyword matching, no AWS call (for dev)
# bedrock = real Bedrock InvokeModel via Converse API
AI_BACKEND=local
AI_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
AWS_REGION=ap-southeast-1

# ── Object storage ───────────────────────────────────────────────────────────
# Options: s3 | local
STORAGE_BACKEND=local
STORAGE_BUCKET=
STORAGE_LOCAL_DIR=./_data/uploads

# ── Database (PostgreSQL only) ────────────────────────────────────────────────
USERSTORE_POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/budgetbot

# ── Flow mode ────────────────────────────────────────────────────────────────
# local = /upload processes CSV inline (sync, no SQS needed) — USE THIS LOCALLY
# aws   = /upload returns presigned S3 URL; parsing is triggered via SQS → Lambda Parser
FLOW_MODE=local

# ── SQS (aws flow only) ───────────────────────────────────────────────────────
SQS_QUEUE_URL=

# ── Lambda names ──────────────────────────────────────────────────────────────
PARSER_LAMBDA_NAME=budgetbot-parser

# ── Confidence threshold ──────────────────────────────────────────────────────
# Transactions with AI confidence below this go to review_status='review'
REVIEW_THRESHOLD=0.60

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Frontend serving ─────────────────────────────────────────────────────────
# true  = backend serves frontend/index.html at /  (convenient for local dev)
# false = frontend deployed separately (CloudFront+S3, Amplify, etc.)
SERVE_FRONTEND=true
# Use the exact frontend origin when developing with Vite and cookies.
CORS_ORIGINS=http://localhost:5173
